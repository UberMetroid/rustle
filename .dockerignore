# ==============================================================================
# DOCKER CONTEXT OPTIMIZATION
# Do not bloat the container with the noise of your local environment.
# Only the signal (source code) is allowed past this firewall.
# ==============================================================================
.git
.git/
.gitignore
.dockerignore
.github/

# Trash from the old JS days
node_modules/
build/

# Do not send compiled truth into the builder. The builder makes its own truth.
target/
dist/

# Do not bake local state into the immutable image.
data/
*.db